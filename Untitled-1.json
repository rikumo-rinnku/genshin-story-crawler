qT1781799568860\"],\"gr41lwkebp7T1781798987937\":[\"0388i273kvwyT1781798998414\"],\"grrgrv7rm5dT1781797661475\":[\"zq8oo4yyukrT1781797673878\"],\"guiv3eygzd8T1781799619872\":[\"89wzc3pts8tT1781799652964\",\"ojx268w70uT1781799653964\",\"cwm98fhetdqT1781799664392\"],\"hh0i65yqbeT1781797742031\":[\"t8cua8s5whbT1781797751340\"],\"imm48ssvhhgT1781802137487\":[\"0wbbii2oohcT1781802838744\",\"349o7fwp5lgT1781802843939\"],\"ix8l3dhfzaT1781798588045\":[\"os3ymyegprT1781798609709\",\"24hgu3zi25xT1781798610610\"],\"jll2jpzpkgcT1781797741005\":[\"t8cua8s5whbT1781797751340\"],\"k58yptlwklkT1781800623837\":[\"eajpilo214jT1781800635536\"],\"kx2eggfe93eT1781798476194\":[\"4y9ngkuchgbT1781798545449\",\"tngl2pvouh8T1781798546263\"],\"m5h60jftg4mT1781798554344\":[\"ix8l3dhfzaT1781798588045\"],\"ni8j9y8x9kaT1781800933289\":[\"u37ubu7d4jmT1781800995666\",\"dytyp0mrtmsT1781800996797\"],\"nntlgvoar6T1781801090434\":[\"u1kt1x06dhrT1781801099001\"],\"ojx268w70uT1781799653964\":[\"vclytr30mpT1781799665747\"],\"os3ymyegprT1781798609709\":[\"d5obpjetorcT1781798621210\"],\"p9tnjmoj7x8T1781799542125\":[\"a13m73dazjT1781799581342\",\"tf3um73ue0nT1781799610085\"],\"pn4j5wiqfchT1781800038530\":[\"q9zkrks65xpT1781800049386\",\"423lu6l4r8aT1781800072583\"],\"psumv0gjsmT1781801647664\":[\"imm48ssvhhgT1781802137487\"],\"q91v5uq0lT1781799083558\":[\"xogs0ebj1kpT1781799107332\"],\"q9zkrks65xpT1781800049386\":[\"2wvcnma1wktT1781800115444\",\"88wjsi4c5wkT1781800145307\"],\"qd4j3oao1khT1781797893627\":[\"41t622jjt7T1781797926494\"],\"rd1xopcbacgT1781797603230\":[\"grrgrv7rm5dT1781797661475\",\"t72xhysj3kiT1781797662544\"],\"t72xhysj3kiT1781797662544\":[\"zq8oo4yyukrT1781797673878\"],\"t8cua8s5whbT1781797751340\":[\"blj122in0qrT1781797854015\"],\"tet31r5v8vaT1781799129532\":[\"dc7crvqh5uT1781799513785\",\"ghtdkeh0sgjT1781799525538\"],\"tf3um73ue0nT1781799610085\":[\"guiv3eygzd8T1781799619872\"],\"tngl2pvouh8T1781798546263\":[\"m5h60jftg4mT1781798554344\"],\"u1kt1x06dhrT1781801099001\":[\"psumv0gjsmT1781801647664\"],\"u37ubu7d4jmT1781800995666\":[\"dsuukyjenwnT1781801006651\"],\"u4iejoh0me9T1781797882275\":[\"qd4j3oao1khT1781797893627\",\"73awwsq8euwT1781797913768\"],\"vclytr30mpT1781799665747\":[\"bqf5slpqwwhT1781799710178\"],\"vipl8ss6f5T1781800307288\":[\"70zthhbk4a8T1781800335571\",\"81rv5q84hpT1781800336500\"],\"w7j1eqnclpoT1781803065428\":[\"eyejmbmavnwT1781803105072\"],\"wr8k7veu7jmT1781798946351\":[\"dt3cidpmzdT1781798987137\",\"gr41lwkebp7T1781798987937\"],\"xogs0ebj1kpT1781799107332\":[\"tet31r5v8vaT1781799129532\"],\"zq8oo4yyukrT1781797673878\":[\"jll2jpzpkgcT1781797741005\",\"hh0i65yqbeT1781797742031\"]},\"contents\":{\"0388i273kvwyT1781798998414\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：可不仅是解决风魔龙事件，还帮我们走完了远征——解决狂猎、「博士」、安德留斯…都有他/她的份。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：哦？我也跟荆夫港的骑士们打听过远征路上的事。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：可惜，也不知道为什么，一个两个都不愿意把话说全了…就像有谁让他们躲着我似的。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：（洛恩…该不会都是你干的吧？）\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：那就趁现在好好聊聊吧，这么伟大的骑士，怎么跟你小子交上朋友了？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：嗯，大概是因为我们都有摩拉般闪耀的「骑士精神」吧，是吧派蒙？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：确实…是像摩拉一样闪耀，哈哈…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：我可是好好遵守了跟你的约定呢，比方说…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：为了和「朋友」建立牢固的信任，我每周都会找骑士们组织集体训练…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：哦哦，就是我跟你说的「团建」对吧，这是培养信任跟默契的好方法呢。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：嗯…这周的「训练方案」就选…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"08zm9o9nmguT1719539158329\":{\"option\":\"旅行者：到底是多大的难事…\",\"dialogue\":\"\",\"icon\":\"\"},\"0sagbgvnnm9lT1781800346374\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：对…这对吗！唉，真是搞不懂他…\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e前往目的地巡逻\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e派蒙：奇怪，好像没有什么痕迹欸？附近真有魔物出没吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e？？？：如果你们想找的是那批举止古怪的魔物，那恐怕是来晚一步了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：看起来，已经有人赶在骑士团之前把它们解决了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：迪卢克？没想到能在这儿遇见你。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：好久不见，阿多诺先生。你们也是，旅行者、派蒙…洛恩。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：呃，这里的魔物…该不会都被哪位暗夜英雄给解决了吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：不是。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"0wbbii2oohcT1781802838744\":{\"option\":\"旅行者：刚才我也在尝试控制幻境…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：你是说问题…出在洛恩自己身上？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：难道是跟「猎月人」的对战，又刺激到了他…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"0wwnjs937kfT1781798780512\":{\"option\":\"旅行者：…知道了，那就陪你走一遭。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：——就知道这招对你们好使。走吧，去荆夫港。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：喂——你这家伙，究竟哪句话是认真的啊！你真的真的不会去骗人吧…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e法尔伽：「须弥发生的情况如上…是时候解决多托雷留在蒙德的遗毒了。」\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e法尔伽：唉…伊洛克…乌萨…好久没听到这些名字了，真叫人头疼…\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e前往荆夫港\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e洛恩：哟，老头子！活得还挺好呀？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：呵，原来你没交代在远征路上啊？这么久不来看老头子，还以为你掉进什么坑里了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：这你可多虑了，这一路都只有我挖坑埋别人的份。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"1oulb7a8lshT1781802902464\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：嗯…洛恩对力量的追求，在很久以前就已经萌生了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：骑士团的叛徒伊洛克，为了谋求更强大的力量，曾经跟「博士」合作进行禁忌的实验…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：洛恩他，就险些成为他们的实验品。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：「博士」的实验？！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e旅行者：（难道跟柯莱一样…）\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：幸运的是，在伊洛克的党羽准备动手之前，骑士团就顺着蛛丝马迹，发现了他们的企图。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：他们匆忙中断了实验，带着受害者紧急转移…却被我们阻击了，受害者都被安然解救了出来。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：…没事了，已经没事了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e哭泣的孩子：呜…呜…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：……\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：我从前也听说过，阿多诺先生的「仁蔼骑士」称号，就是在那起事件后被授予的吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：不过没想到，洛恩副队长…居然会是那时的当事人。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：唉…这名号我实在受之有愧。虽然救出了被困的孩子，却没能揪出藏在幕后的伊洛克。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：…甚至就连他们的实验地点都没找到。也没能让洛恩，彻底摆脱那时的影响。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：他以前总觉得只有掌握了力量，才能不被人左右。我本来指望他在远征之后看开一点，却没想到…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"24hgu3zi25xT1781798610610\":{\"option\":\"旅行者：我有些好奇阿多诺是谁了。\",\"dialogue\":\"\",\"icon\":\"\"},\"26ptn7wbxqlT1719539095521\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e派蒙：你们这是遇到什么难事了吗？\u003c/p\u003e\u003cp\u003e娜维娅：没错！我的好搭档，有个天大的难事，眼下只有你们能帮我们解决！\u003c/p\u003e\u003cp\u003e派蒙：这么夸张？\u003c/p\u003e\u003cp\u003e克洛琳德：毫不夸张。已经走投无路了。\u003c/p\u003e\",\"icon\":\"\"},\"2bb1fu2uucpT1781799816011\":{\"option\":\"旅行者：……\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：咳，那什么，虽然我没有亲眼见过你们说的那个「猎月人」，但我觉得「骑士」的强大绝不只体现在力量。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：我接下来要去处理一些重要工作，洛恩，你们也一起来吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：重要工作？我听说你早就是半隐退的状态了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：哈，跟着来不就清楚了吗？这可是「仁蔼骑士」的必修课呢。\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e跟随阿多诺完成工作\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e麦克斯：啊！「仁蔼骑士」来了！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e莫里兹提尔：阿多诺爷爷！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e北地猫：喵~\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e汉娜洛蕾：嘿——不要急，不要抢！排好队慢慢来！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：欸，没事没事，孩子嘛，热闹些是好事。来，这是今天的糖。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e莫里兹提尔：——谢谢爷爷！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e麦克斯：真好吃！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…这就是你说的「重要工作」？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：这才只是个开头呢，「新兵」，好好跟上我！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…知道了，「队长」。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：哈…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"2bksel5k7lcT1781798460583\":{\"option\":\"旅行者：所以，这就是你用法尔伽的名义…\",\"dialogue\":\"\",\"icon\":\"\"},\"2he7k0m99qbT1781800155740\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：日常啊…回蒙德也有段时间了，但还是不好适应。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：明明就在不久前，风餐露宿、险象环生，才是我们的「日常」。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：那时候你还在远征吧？现在已经可以放下心啦！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：是吗？我倒是觉得，「日常」从来就不是什么能让人放心的东西。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：蒙德的风雪是被风神吹散的，如今的和平也是骑士团征讨来的。只要遭遇一点偶然，就会顷刻崩塌。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：所以…与其等着安稳的「日常」被谁颠覆，不如从一开始就置身于「非日常」里，反而让人安心。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"2ku4y5wb49uT1781800037532\":{\"option\":\"旅行者：…你没事吧？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：我反倒想问你——为什么会这么熟练？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"2wvcnma1wktT1781800115444\":{\"option\":\"旅行者：虽然你看着有些失望…\",\"dialogue\":\"\",\"icon\":\"\"},\"349o7fwp5lgT1781802843939\":{\"option\":\"旅行者：出问题的应该不是魔法本身。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：你是说问题…出在洛恩自己身上？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：难道是跟「猎月人」的对战，又刺激到了他…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"3ar6h3biklqT1781803019073\":{\"option\":\"旅行者：跟「猎月人」的战斗…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：居然是这样…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：唉…要陪着这样的他演「朋友」，还挺不容易吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：是啊…啊！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"3itwnf29snfT1781797883305\":{\"option\":\"旅行者：没准就是想溜出来喝酒…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：无法反驳…不过万一他真有什么要紧事呢？他也不是没有正经的时候…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"41t622jjt7T1781797926494\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e凯亚：再见——记得要来参加授勋仪式呀。\u003c/p\u003e\u003cdetails class=\\\"custom-details\\\"\u003e\u003csummary\u003e\u003c/summary\u003e\u003cdiv data-type=\\\"detailsContent\\\"\u003e\u003cp\u003e\u003cem\u003e凯亚：授勋仪式上的酒水…还是得我亲自把关呀。\u003c/em\u003e\u003c/p\u003e\u003c/div\u003e\u003c/details\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e前往骑士团\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e法尔伽：…关于授勋仪式上的安排，还有什么问题吗？或者说…你有在听吗？\u003c/p\u003e\u003cp\u003e洛恩：嗯、好、我没意见。\u003c/p\u003e\u003cp\u003e法尔伽：…咳！洛恩！\u003c/p\u003e\u003cp\u003e洛恩：啊…我能走了吗？多谢咯，大团长！\u003c/p\u003e\u003cp\u003e法尔伽：——给我回来！\u003c/p\u003e\u003cp\u003e法尔伽：唉…现在的年轻人是怎么回事？我当初拿到称号的时候，可激动得一夜没睡…\u003c/p\u003e\u003cp\u003e洛恩：哦？那你那晚上喝掉了几桶酒？\u003c/p\u003e\u003cp\u003e法尔伽：…重点不在这儿吧！\u003c/p\u003e\u003cp\u003e法尔伽：唉…算了，我也清楚，你对骑士的称号和队长的职位兴趣都不大。\u003c/p\u003e\u003cp\u003e法尔伽：但让你继承「仁蔼骑士」的名号…是阿多诺正式退役前最后的心愿。\u003c/p\u003e\u003cp\u003e洛恩：……\u003c/p\u003e\u003cp\u003e法尔伽：你回蒙德已经有一段时间了吧，平时也都驻守在荆夫港…就没想过要去见见他吗？\u003c/p\u003e\u003cp\u003e洛恩：…远征回来之后要交的报告太多了啊，一直抽不出空来。\u003c/p\u003e\u003cp\u003e法尔伽：哦？但是看你交上来的报告，倒像是君特的笔迹呀？\u003c/p\u003e\u003cp\u003e洛恩：嘁…连这点「文书工作」都没做好…那家伙还是缺少锻炼啊。\u003c/p\u003e\u003cp\u003e法尔伽：总之——去跟阿多诺好好谈谈吧，为了「仁蔼骑士」和队长之位能顺利交接。\u003c/p\u003e\u003cp\u003e法尔伽：这是来自大团长的直接命令，可别再拿什么工作当借口了。\u003c/p\u003e\u003cp\u003e洛恩：哈…\u003c/p\u003e\u003cp\u003e法尔伽：不用这么愁眉苦脸，我大概知道你们在「远征」之前的约定。需要打掩护的话…\u003c/p\u003e\u003cp\u003e法尔伽：…咳，鉴于阿多诺的情况特殊，我可以破例陪你走一趟。\u003c/p\u003e\u003cp\u003e洛恩：…还是算了吧，你们两位一块共事了那么久，说的话是真是假，他一眼就能看出来。\u003c/p\u003e\u003cp\u003e法尔伽：唉，这倒也是…再说我现在还有其他事要忙…那还有什么人能陪你去吗？\u003c/p\u003e\u003cp\u003e法尔伽：既要让人信服，又不能跟阿多诺太熟…蒙德城里还有这样的骑士吗？\u003c/p\u003e\u003cp\u003e洛恩：呵，你说的这位「骑士」…好像正好来蒙德了呀。\u003c/p\u003e\",\"icon\":\"\"},\"423lu6l4r8aT1781800072583\":{\"option\":\"旅行者：这就是冒险家。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：难以想象，那个「荣誉骑士」居然成天在做这些事…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：我们也不是每天都在对付想毁灭世界的家伙啦…不如说这种家伙要是每天都有也太恐怖了吧！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"47b0bec0mbfT1781803056181\":{\"option\":\"旅行者：果然瞒不过你。\",\"dialogue\":\"\",\"icon\":\"\"},\"4b0xrur5kvuT1781799804103\":{\"option\":\"旅行者：那毕竟是曾匹敌世界的罪人…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：是啊！我们最后也是用了他自己的力量，才把他给放逐了…你也别太在意啦！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…但他也曾是一介凡人，不对吗？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"4emxp9lwmnrT1781800924428\":{\"option\":\"旅行者：该不会…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：没错，就是你们的老熟人——「博士」。准确来说，那应该算是他的切片之一？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：所以魔龙乌萨的苏醒…完全就是那个「博士」切片的什么阴谋吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：也不全是。就算是愚人众的执行官，只凭他一人，也很难在蒙德掀起这样的风浪。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"4gxfgtlum69T1781797545661\":{\"option\":\"旅行者：就像我的「荣誉」？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e凯亚：嗯…也可以这么说！只可惜那时候忙着解决特瓦林被侵蚀的问题，没给你也办一场仪式…我想想，要不这次给你补上？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"4i7cpk8uv9tT1781800213911\":{\"option\":\"旅行者：……\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：——就是因为这么脆弱，所以才需要我们骑士去守护吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：啊，你已经发完糖了吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：嗯，看来你们这边也告一段落了？没想到你还真能耐得住性子…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：接下来的工作，应该能让你好好活动一下了——我们要去巡查周边魔物的情况。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：魔物？骑士团的人手不够吗？你有好几年没拿过剑了吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：嘿，我可还没正式退役呢！只是巡查而已，我还是干得动的。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：虽说前阵子是有点难捱…不过你看我现在，不是精神得很？不趁着现在多动一动，往后没机会了可怎么办？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：你还真是闲不下来…行吧，是要上哪巡查？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：最近在郊外出现了一些举止古怪的魔物，虽然还没有伤人的记录，但多个心眼总没错。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：往常我都只能在附近巡逻，看看有没有魔物靠近城镇，但这回可有你们在呢。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：嘿嘿——别说巡查了，统统打翻都没问题！是吧？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"4slsvqushzjT1719539249944\":{\"option\":\"旅行者：先听听看…\",\"dialogue\":\"\u003cp\u003e\u003c/p\u003e\",\"icon\":\"\"},\"4y9ngkuchgbT1781798545449\":{\"option\":\"旅行者：这是哪门子惯例啊！\",\"dialogue\":\"\",\"icon\":\"\"},\"52ju4n12uydT1781800469476\":{\"option\":\"旅行者：真不是？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e迪卢克：…我不认识你们口中的那位暗夜英雄，但从坊间传闻来看，这片战场残留的痕迹与他的行事风格不符。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：更像是有谁…早早获悉了魔物的情报前来「清理」，连一点残骸都没有留下。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：哦？听迪卢克老爷的意思，像是来调查的？那可真奇怪，晨曦酒庄的老板，怎么会突然对魔物感兴趣？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：晨曦酒庄的商队也会经过荆夫港，我听了传闻放心不下，就打算亲自过来看看了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：倒是骑士团，远征期间姑且不论…回来之后还是人手不足吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：哈，你还是跟从前一样严格。这巡查工作是我自己给自己找的，趁着还能动弹就多动一动。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：几十年都这么过来了，实在闲不下来啊。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：…辛苦您了，「仁蔼骑士」前辈。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：迪卢克…居然会喊他前辈？连法尔伽都没这待遇吧！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：呵，没准是法尔伽自己的问题呢。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：唉，伊洛克那时候只是占了大团长不在蒙德的便宜，否则哪里能掀起那些风浪？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：如果大团长和赤杨骑士他们那时都在，一定不会让你父亲克利普斯击退魔龙的功绩被轻易抹杀。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：…也不至于只有我们几个留守蒙德的老家伙，为你父亲发声。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：——但他们那时候不在，不是么？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：闲话就聊到这儿吧，既然这里没有什么线索，那我也没有逗留的理由。再见，旅行者、派蒙。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e迪卢克：还有…保重，「仁蔼骑士」。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：唉…乌萨、伊洛克…有些家伙就算消失了，但留下的伤口也不会就这么消失啊。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"58im9p2brhuT1781803028575\":{\"option\":\"旅行者：你早就看出来了吧。\",\"dialogue\":\"\",\"icon\":\"\"},\"5fv6brypwoqT1781800923072\":{\"option\":\"旅行者：愚人众…执行官？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：没错，就是你们的老熟人——「博士」。准确来说，那应该算是他的切片之一？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：所以魔龙乌萨的苏醒…完全就是那个「博士」切片的什么阴谋吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：也不全是。就算是愚人众的执行官，只凭他一人，也很难在蒙德掀起这样的风浪。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"6ksyefn4h73T1781797575069\":{\"option\":\"旅行者：算啦算啦，都过去这么久了。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：而且这趟授勋仪式，是为远征凯旋的骑士们准备的吧？总不能抢了他们的风头呀！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：再说比起在仪式上受勋…还是直接受邀当嘉宾听着更厉害！就像什么大前辈一样！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"70zthhbk4a8T1781800335571\":{\"option\":\"旅行者：说句「拿你试试刀吧」之类的？\",\"dialogue\":\"\",\"icon\":\"\"},\"73awwsq8euwT1781797913768\":{\"option\":\"旅行者：回头再聊，凯亚。\",\"dialogue\":\"\",\"icon\":\"\"},\"81rv5q84hpT1781800336500\":{\"option\":\"旅行者：或者是「又一个实验对象」？\",\"dialogue\":\"\",\"icon\":\"\"},\"88mf9bl1405T1781801087168\":{\"option\":\"旅行者：就算他们逃得一时…\",\"dialogue\":\"\",\"icon\":\"\"},\"88wjsi4c5wkT1781800145307\":{\"option\":\"旅行者：但这才是我们的日常。\",\"dialogue\":\"\",\"icon\":\"\"},\"89wzc3pts8tT1781799652964\":{\"option\":\"（盐。）\",\"dialogue\":\"\",\"icon\":\"\"},\"8ft60o4jfi5T1719539864072\":{\"option\":\"旅行者：需要向你发出决斗申请吗…\",\"dialogue\":\"\",\"icon\":\"\"},\"8x7ewlgvgnmT1719539812216\":{\"option\":\"旅行者：二位好。\",\"dialogue\":\"\u003cp\u003e林尼：我只能算个「挂名成员」吧，没参加过几次活动。在布法蒂公馆，倒是经常由我担任主持人，陪琳妮特和菲米尼玩类似的游戏。\u003c/p\u003e\u003cp\u003e林尼：不过，自己作为玩家体验剧本还是头一次呢，希望能和大家玩得开心。\u003c/p\u003e\u003cp\u003e芙宁娜：我不是俱乐部的会员。只是一大早被克洛琳德敲门叫醒，说有个不错的剧本可以体验，这才决定加入的。\u003c/p\u003e\u003cp\u003e克洛琳德：如果你感兴趣，我可以当你的介绍人，入会费打六折。\u003c/p\u003e\u003cp\u003e芙宁娜：我还是先看这次的剧本质量再考虑啦，体验好的话我就加入。\u003c/p\u003e\u003cp\u003e派蒙：克洛琳德是经常玩「桌上剧团」吗？\u003c/p\u003e\u003cp\u003e林尼：她可是俱乐部数一数二的「资深主持人」哟。\u003c/p\u003e\u003cp\u003e芙宁娜：嗯，以前跟我还是上下级关系的时候，我就知道这一点了。\u003c/p\u003e\u003cp\u003e克洛琳德：…一点业余爱好而已，不必那么惊讶。\u003c/p\u003e\u003cp\u003e派蒙：天哪，平时看你都是身为决斗代理人威严的一面，完全想象不到你带人玩桌上剧团的样子呢。\u003c/p\u003e\",\"icon\":\"\"},\"91ggzyq4e3qT1781798712974\":{\"option\":\"旅行者：…他自己没有参加远征吗？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：他倒是想，毕竟从前都已经跟大团长出征过这么多次了，怎么能错过这最盛大的一次？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：可惜，不管是岁数还是身体，都不由他自己说了算…为「仁蔼」之名寻个归处，大概就是他最后的心愿了吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：这样啊，旅行者…那我们…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"92ybus708stT1781798464070\":{\"option\":\"旅行者：…把我们喊来这里的原因？\",\"dialogue\":\"\",\"icon\":\"\"},\"9727auf9h8iT1781799804909\":{\"option\":\"旅行者：掌握着远超想象的深渊力量。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：是啊！我们最后也是用了他自己的力量，才把他给放逐了…你也别太在意啦！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…但他也曾是一介凡人，不对吗？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"99y0g7hqtpT1719539269497\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e娜维娅：旅行者，派蒙…你们愿意…\u003c/p\u003e\u003cp\u003e娜维娅：——来玩《逐影猎人：审判之时》吗？！\u003c/p\u003e\u003cp\u003e派蒙：什么东西？\u003c/p\u003e\u003cp\u003e克洛琳德：一个由枫丹「桌上剧团」俱乐部推出的游戏剧本。\u003c/p\u003e\u003cp\u003e娜维娅：你们听过「桌上剧团」吧？就是和好朋友围在桌前，扮演剧中角色，参与剧本故事的游戏。我小时候就爱玩。\u003c/p\u003e\u003cp\u003e派蒙：好像挺有趣的！\u003c/p\u003e\u003cp\u003e娜维娅：我和克洛琳德都是俱乐部里的老会员了。最近，有人找到我，说他们出了一个新剧本，想请人免费试玩。\u003c/p\u003e\u003cp\u003e娜维娅：这可是一个全新的剧本欸！我们是第一批体验者！\u003c/p\u003e\u003cp\u003e克洛琳德：试玩阶段的剧本一般来说会有很多瑕疵，但这次的我觉得不错，完成度比较高，作者的考据也很到位。\u003c/p\u003e\u003cp\u003e娜维娅：欸停停停！剧本我一个字没看就直接拿给你了，千万别在这里剧透！\u003c/p\u003e\u003cp\u003e克洛琳德：…总之，这个剧本要求四位扮演者，现在三缺一。\u003c/p\u003e\",\"icon\":\"\"},\"a03s0y2954qT1781799568860\":{\"option\":\"（放五瓶胡椒粉）\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：最后撒些香辛料吧——\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"a13m73dazjT1781799581342\":{\"option\":\"（全都加上！）\",\"dialogue\":\"\",\"icon\":\"\"},\"aecgey98g3qT1781802866721\":{\"option\":\"旅行者：…又？\",\"dialogue\":\"\",\"icon\":\"\"},\"az17hddezgtT1781797316551\":{\"option\":\"旅行者：授勋仪式？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e凯亚：哦？荣誉骑士、派蒙？哈，看来我不用再费心思派人去邀请你们了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：能有这么重量级的嘉宾到场，远征军的同僚们也会高兴的吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：骑士？授勋？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：你看，骑士团里不是有许多骑士，都有独属于自己的「称号」吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：就像大团长的「北风」、优菈队长的「浪花」…有的来自于传承，有的来历特殊…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：而绝大多数情况下，它们都是用来表彰一名骑士的品行与功绩。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"b5v4t27huopT1781802889617\":{\"option\":\"旅行者：…刺激？\",\"dialogue\":\"\",\"icon\":\"\"},\"b9w1hm9ostbT1719539400657\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e克洛琳德：好。那现在问题就解决了。\u003c/p\u003e\u003cp\u003e娜维娅：太棒了！我这就去俱乐部叫剧本管理人过来！\u003c/p\u003e\u003cp\u003e派蒙：剧本管理人？剧本不就在克洛琳德手里吗？\u003c/p\u003e\u003cp\u003e克洛琳德：配合这个剧本，俱乐部推出了全新的游玩方式。\u003c/p\u003e\u003cp\u003e克洛琳德：一开始主持人手中的剧本并不完整，需要跑完当前阶段的剧情，才能从剧本管理人那边接到下一阶段的剧本。\u003c/p\u003e\u003cp\u003e克洛琳德：而且，俱乐部还会在现实中搭建剧中场景，让参与者身临其境，实景参与。第一天的游玩地点，得等剧本管理人告诉我们才知道。\u003c/p\u003e\u003cp\u003e派蒙：哇，听起来写这个剧本的人真的很用心呢！\u003c/p\u003e\u003cp\u003e娜维娅：嘿嘿，而且还很有悬念对吧？就连主持人都不知道故事的结局呢！\u003c/p\u003e\u003cp\u003e克洛琳德：我很期待和你们共同见证。\u003c/p\u003e\u003cp\u003e娜维娅：你们先去和其他人会合吧，他们还在千织屋等着呢，我待会儿就和剧本管理人一起过来。\u003c/p\u003e\u003cp\u003e克洛琳德：好，不要着急，小心看路。\u003c/p\u003e\u003cp\u003e娜维娅：你怎么把我说得像个小孩子一样？\u003c/p\u003e\u003cp\u003e娜维娅：唔…让我想想，这次该扮演一个什么样的角色呢？\u003c/p\u003e\u003cp\u003e克洛琳德：…希望这次你能学一些正常的技能。另外，别再试图对每一只见到的动物都使用「说服」了…\u003c/p\u003e\u003cp style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e前往「千织屋」与其他人会合\u003c/strong\u003e\u003c/p\u003e\u003cp\u003e克洛琳德：久等了。\u003c/p\u003e\u003cp\u003e芙宁娜：哦，你们回来了。咦？是旅行者和派蒙？\u003c/p\u003e\u003cp\u003e林尼：真惊喜，原来最后找到了你们一起来玩吗？\u003c/p\u003e\u003cp\u003e派蒙：林尼！还有芙宁娜！另外两位玩家居然是你们呀！你们也是「桌上剧团」俱乐部的会员吗？\u003c/p\u003e\",\"icon\":\"\"},\"bldpcm4o71dT1781800605820\":{\"option\":\"旅行者：乌萨？\",\"dialogue\":\"\",\"icon\":\"\"},\"blj122in0qrT1781797854015\":{\"option\":\"旅行者：找我有事吗？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e波尔托：呃…大团长想请您去骑士团总部谈谈，说是有要事商量！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：法尔伽？他找我们有什么要事？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"bqf5slpqwwhT1781799710178\":{\"option\":\"旅行者：还真…没说…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：就是这样，老头子，你就放心把那什么…「仁蔼骑士」给传下来，然后好好去休息吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：欸，话不是都还没讲完吗？我听说你在挪德卡莱的时候，还对上过一个强敌？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：名字是叫…「猎月人」？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：……！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：还有这回事！怎么都没听你跟法尔伽讲过？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…哈，没什么可讲的，自然也不必讲…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…我跟着大团长去埋伏过他，结果不但没派上用场，反而还挨了他好几拳呢。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：之后就在营地里，一连躺了好几天，等到能下床的时候，就听见了…你们联手放逐猎月人的消息。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：这样啊…难怪打猎月人的时候都没见到你…明明这么喜欢打架…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"c2eo6az2f2oT1781799770630\":{\"option\":\"旅行者：派蒙…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：啊！抱歉…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：用不着抱歉，你说得又没错。是我自己还不够强…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：迟钝、弱小，不堪一击的…凡人。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e法尔伽：洛恩！喂！洛恩…嘁！你们带着他先撤！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"cwm98fhetdqT1781799664392\":{\"option\":\"（香辛料。）\",\"dialogue\":\"\",\"icon\":\"\"},\"d5obpjetorcT1781798621210\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：…「仁蔼骑士」阿多诺，是第五小队的队长，我的直属上级。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：「仁蔼骑士」！那不是凯亚说的…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：我即将继承的骑士称号？外头似乎都在这么传。但其实他过去曾跟我立下过约定…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：作为推荐我加入远征队的条件，他希望我能在远征中好好思考，怎么成为一名正派的骑士。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：等到远征结束，再从阿多诺那里继承「仁蔼骑士」的名号…和队长的职务。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：呃，等等，也就是说…你其实是因为没自信能取得他的认可，所以才要我们陪你过去演戏？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：不要误会，我对名号跟职位都没兴趣，只是…不想听他啰嗦而已。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"dc7crvqh5uT1781799513785\":{\"option\":\"（放一瓶盐）\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：不如再放些胡椒粉…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"dsuukyjenwnT1781801006651\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：…在迪卢克刚成年的时候，魔龙乌萨袭击了晨曦酒庄的商队。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：这本是一次普普通通的袭击，是他们煽动恐惧的惯用伎俩。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：但不可一世的魔龙，却被一介商人——迪卢克的父亲，克利普斯给击退了…尽管他也付出了生命的代价。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：魔龙败退的消息绝不利于伊洛克借助恐惧上位的图谋，所以他用「维护骑士团名誉」作借口，封锁了事件真相。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：如果我当时能早一点发现，伊洛克已经跟「博士」沆瀣一气…也许就能阻止这一切了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：嘿，别什么都往自己身上揽，伊洛克隐藏得确实很深，直到「魔龙事件」前都没露出过狐狸尾巴。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…就连当时的受害者，都不知道自己是被谁所害。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：唉…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"dt3cidpmzdT1781798987137\":{\"option\":\"旅行者：正是在下。\",\"dialogue\":\"\",\"icon\":\"\"},\"dytyp0mrtmsT1781800996797\":{\"option\":\"旅行者：那他跟迪卢克的关系是？\",\"dialogue\":\"\",\"icon\":\"\"},\"eajpilo214jT1781800635536\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：……\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：嗯？要我来说吗？好啊——这个乌萨是条扛揍的魔龙，那个伊洛克是个欠揍的督察长…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：咳…还是让我来吧。所谓乌萨，是一千年前就在蒙德出现过的魔龙，凭着强大的力量为祸一方。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：西风骑士团创立后，初代大团长温妮莎在风神的帮助下封印了乌萨，魔龙就此陷入沉寂…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：然而就在近十年前，它却又一次在蒙德出现！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：还刚好挑了大团长不在的时间。不仅如此，它会在骑士团举兵讨伐的时候悄然蛰伏，而在部队休整时又突然现身…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：这也太刚好了吧！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：到最后，还「刚好」被一位愚人众执行官「顺路灭杀」了。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"ei1cdevmfshT1781803019904\":{\"option\":\"旅行者：反而加重了他的执念？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：居然是这样…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：唉…要陪着这样的他演「朋友」，还挺不容易吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：是啊…啊！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"ewllh0qqr0dT1711546416025\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e西风大教堂的广场之前，骑士们正为了即将到来的授勋仪式而忙碌着…\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e前往蒙德城\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e派蒙：咦？最近好像不是什么节日吧？怎么这么热闹？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：…再多准备几圈彩旗，还有庆祝用的酒水呢？嗯…让我亲自把把关。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：这可是远征军凯旋后的第一场授勋仪式，办得越隆重越好！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e雷蒙德：包在我们身上！凯亚队长！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"eyejmbmavnwT1781803105072\":{\"option\":\"旅行者：砂糖？怎么了？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e砂糖：稍微有些在意的事，「荣誉骑士」，方便跟我来看看吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：…奇怪，虽然阿多诺先生说是洛恩的「执念」引发了幻境失控。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：但「模拟训练泡·零贰式」的各种参数都很正常…反而是洛恩副队长那时爆发出的力量，我总觉得有点不寻常。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：连砂糖也没见过？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：嗯，那好像不是我们常见的元素力，但也不是阿贝多先生说的「虚界力」…你有什么头绪吗？荣誉骑士。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e旅行者：（在那一瞬间，似乎确实感觉到了…什么似曾相识的力量…但也无法确信。）\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：砂糖的意思是…是洛恩身上有什么古怪？呃…他不会在捣鼓什么危险的东西吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：我…我不是这个意思，只是如实报告情况而已。没有证据的话，可不能随便怀疑自己的同伴呀。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：你、你说的也对，这种情况可遇见过太多次了…还是谨慎点吧…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：你今天怎么会来这？明明之前都说好了…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：法尔伽的命令，我也没办法。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：那你也太不小心了，居然用这么大的力量…唉…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：——万一暴露了怎么办？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：那就在暴露之前…加速我们的实验吧。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"ghtdkeh0sgjT1781799525538\":{\"option\":\"（放三瓶盐）\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：不如再放些胡椒粉…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"gr41lwkebp7T1781798987937\":{\"option\":\"旅行者：就是我！\",\"dialogue\":\"\",\"icon\":\"\"},\"grrgrv7rm5dT1781797661475\":{\"option\":\"旅行者：谁的记录？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e凯亚：「西风骑士团最年轻的队长」——上一任记录的保持者是前骑兵队长，迪卢克。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：呵…真好奇到时候，「前队长」会是一副什么表情。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"guiv3eygzd8T1781799619872\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：嗯，果然烤肉还是得这么烤！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：来，要尝点烤肉吗？你也饿了快三天了吧？还是说…你想尝点别的？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"hh0i65yqbeT1781797742031\":{\"option\":\"旅行者：靠你了，派蒙！\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：嘿嘿！交给我！洛恩是吧…洛恩…「匕首骑士」？「坏笑骑士」？呃…「扛揍骑士」！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"il3ihnmme3eT1719539367834\":{\"option\":\"旅行者：朋友有难怎能不帮！\",\"dialogue\":\"\",\"icon\":\"\"},\"imm48ssvhhgT1781802137487\":{\"option\":\"旅行者：…你确定吗？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：我还没有丧气到连记忆里的他都会怕了，就当是让我确认一下…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：现在的我是不是还像他说的一样…不堪一击。\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e挑战「猎月人」\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e派蒙：你…你小心点啊！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：测试…开始！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：这家伙…在那之后，又变强到这种程度了吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e「猎月人」：现在…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e「猎月人」：该换你们感受恐惧了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：不过是…记忆而已！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e「猎月人」：区区…凡人！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：这话…还是留给你自己吧！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：洛恩…喂！洛恩——\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：是记忆失控了？旅行者，请帮我控制住它！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…唔！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：——快醒醒！洛恩！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：……！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：哈…哈…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：阿多诺先生！你…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：我没事…只是闪到腰罢了，休息一下就行…倒是洛恩…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：——咳！哼…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：强行收住最后那一击…反而让你自己受伤了吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：希奥多，带洛恩去检查一下，不要留下什么暗伤。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：好…洛恩，先跟我来吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：……\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：——咳！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：阿多诺先生！你没事吧！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：没事…人老了嘛，身上难免会落下点病根…稍微剧烈点就会这样，呼…回头让希奥多给再我开点药就成。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：洛恩这家伙…到底是怎么了？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：会是这个魔法哪里出了问题吗？但如果是幻境再现出的记忆出了问题，荣誉骑士应该能察觉到…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"ix8l3dhfzaT1781798588045\":{\"option\":\"旅行者：你说的那些问题呢！\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：问…问题就是要拿来解决的！为…为了朋友…！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"jll2jpzpkgcT1781797741005\":{\"option\":\"旅行者：要给人起称号？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：嘿嘿！交给我！洛恩是吧…洛恩…「匕首骑士」？「坏笑骑士」？呃…「扛揍骑士」！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"k58yptlwklkT1781800623837\":{\"option\":\"旅行者：伊洛克？\",\"dialogue\":\"\",\"icon\":\"\"},\"kx2eggfe93eT1781798476194\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：那时候我可愁坏了，正巧看到两位从窗外走过——这就是风神的指引吧，你们不觉得吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：一点也不觉得！你的意思不就是要我们去帮你骗人吗！虽然还没搞清楚情况…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：不不不，诚信可是骑士的基本美德，我只是想请荣誉骑士「出演」一下我的「朋友」而已。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…顺便佐证一些远征中的经过。放心吧，你们要是听见我说一句谎话…就上来给我一拳？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：但还是有一堆问题吧？我们一直到远征的尾声才跟法尔伽合流，甚至都不是在挪德卡莱遇到的你…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：啊，对了，说起「朋友」，我听说朋友之间还有个惯例？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：——这是我准备的「朋友费」。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"lkhv2wqgnmdT1719539046897\":{\"option\":\"旅行者：…你，你们要干什么？\",\"dialogue\":\"\",\"icon\":\"\"},\"m5h60jftg4mT1781798554344\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：…好…好多！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：都是执行特别任务时发下来的津贴，不知不觉就积累起来了。我平时又用不上，不如送给「朋友」？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：旅行者…我觉得多一个朋友…也不是不能考虑？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"ni8j9y8x9kaT1781800933289\":{\"option\":\"旅行者：所以，还有别的黑幕？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：嗯，还有一个人，被超凡的「力量」迷惑，在暗中与「博士」勾结…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：他就是当时西风骑士团的督察长，骑士团百年来最大的叛徒——伊洛克。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"nntlgvoar6T1781801090434\":{\"option\":\"旅行者：现在也都付出了代价。\",\"dialogue\":\"\",\"icon\":\"\"},\"ojx268w70uT1781799653964\":{\"option\":\"（胡椒。）\",\"dialogue\":\"\",\"icon\":\"\"},\"os3ymyegprT1781798609709\":{\"option\":\"旅行者：先不论为了朋友还是朋友费…\",\"dialogue\":\"\",\"icon\":\"\"},\"p704ii3evlT1719539905528\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e克洛琳德：你说笑了。我不会这样为难玩家。\u003c/p\u003e\u003cp\u003e克洛琳德：工作是工作，生活是生活。审判庭上的我，代表枫丹的律法与规则，赐予想要维护自身荣誉的人一场公正的决斗。不掺任何私情。\u003c/p\u003e\u003cp\u003e克洛琳德：但生活中，我和大家一样，是个普普通通的人，生气难过之类的情绪，也是会有的。\u003c/p\u003e\u003cp\u003e芙宁娜：骗人的吧，你在我旁边这么久，我从没看你掉过眼泪，生气倒是有过不少…还是说你只是看起来像生气了？\u003c/p\u003e\u003cp\u003e克洛琳德：那时的我也是工作状态。\u003c/p\u003e\u003cp\u003e芙宁娜：是这样吗？但总觉得你在生活中情绪波动也不大。\u003c/p\u003e\u003cp\u003e克洛琳德：你想看我哭吗？那可能有些困难。生气或许会更容易些。\u003c/p\u003e\u003cp\u003e芙宁娜：啊不不不，我不是这个意思…\u003c/p\u003e\u003cp\u003e娜维娅：我回来啦！向大家介绍一下，这位就是此次剧本的负责人，弗洛莱恩先生！\u003c/p\u003e\u003cp\u003e弗洛莱恩：各位好。\u003c/p\u003e\u003cp\u003e派蒙：你好你好。咦？难道弗洛莱恩先生也是决斗代理人吗？\u003c/p\u003e\u003cp\u003e弗洛莱恩：哦，不是的，这是俱乐部提供的演出服。我偶尔还会扮演剧本中的其他角色。\u003c/p\u003e\u003cp\u003e林尼：还真是辛苦的工作呢。\u003c/p\u003e\u003cp\u003e弗洛莱恩：这没什么。为了能让扮演者更为沉浸地体验故事，这是我们该做的。\u003c/p\u003e\u003cp\u003e弗洛莱恩：那么我为各位简单介绍一下——\u003c/p\u003e\u003cp\u003e弗洛莱恩：此次的剧本，是参考逐影猎人的历史改编而成。诸位将亲自扮演那个时代的逐影猎人，解决在王城发生的一系列事件。\u003c/p\u003e\u003cp\u003e派蒙：呃…我对逐影猎人的历史不是那么熟悉，应该没什么影响吧？\u003c/p\u003e\u003cp\u003e弗洛莱恩：哦，这完全没问题。简单介绍的话，「逐影猎人」指的是那些继承了特殊的剑技，猎杀魔物、守护城市的人。\u003c/p\u003e\u003cp\u003e弗洛莱恩：关于他们的故事，最早能追溯到很久以前的雷穆利亚王朝，以及第一位猎人「卡西奥多」…\u003c/p\u003e\u003cp\u003e弗洛莱恩：但更加详细的，就留给各位之后去寻找和发现吧。\u003c/p\u003e\u003cp\u003e克洛琳德：嗯，我也会在此过程中为你们进一步解说。\u003c/p\u003e\u003cp\u003e弗洛莱恩：那么…咳咳！各位勇敢的猎人啊，你们准备好踏入一场未知的冒险之旅了吗？\u003c/p\u003e\u003cp\u003e派蒙：哦！气氛一下子就上来了呢！\u003c/p\u003e\u003cp\u003e弗洛莱恩：很好，我已经看到了你们坚毅的眼神。就请前往此处，开启你们的旅途吧！\u003c/p\u003e\u003cp\u003e芙宁娜：根据故事走向，前往特定情景吗？听起来挺新颖。所以信封里写了什么？\u003c/p\u003e\u003cp\u003e克洛琳德：是第一阶段剧本情景的具体位置，还有场地使用许可。准备得挺周全。\u003c/p\u003e\u003cp\u003e克洛琳德：请各位检查随身物品，防止遗漏。准备好后，就随我前往指定的地点吧。\u003c/p\u003e\u003cp\u003e派蒙：好欸！逐影猎人小队，出发！\u003c/p\u003e\",\"icon\":\"\"},\"p9tnjmoj7x8T1781799542125\":{\"option\":\"（放三瓶胡椒粉）\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：最后撒些香辛料吧——\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"pn4j5wiqfchT1781800038530\":{\"option\":\"旅行者：打架都没见你这么累。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：我反倒想问你——为什么会这么熟练？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"psumv0gjsmT1781801647664\":{\"option\":\"旅行者：你也用过吗？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：回来之后没多久，就有人告诉我，能用这玩意快速了解远征期间在蒙德发生的大小事件。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…不过效果这么夸张的魔法，只拿来听个故事，实在是太浪费了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：哈哈，可不止你一个人这么认为，调查小队很快就意识到它的潜力，想应用到「模拟训练」上了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：如果能再现出前辈们记忆里的强敌，为新晋的骑士提供真实又安全的「模拟训练」，应该能帮助培养更多战力吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：不过我们调试了很久，都没完全掌握它的原理，也很难把控真实跟安全的界限…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：「安全」…听起来不像是艾莉丝会好好考虑的事。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：嚯？有点意思，让我试试。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：老头子，这差事你就不用上了吧？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：用不着操心，这把老骨头还剩下几斤几两，我还是掂得清的。过来只是提供一下脑袋里的「记忆」而已。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：哦？那你们原本安排的测试员是？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：砂糖小姐，测试已经安排…啊…洛恩？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：…希奥多？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：你怎么…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：——我是凑巧跟着阿多诺来测试这个「模拟训练泡」的，所以，你就是原定的测试员？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：啊…是、是的，那这几位是…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：咳，我来帮你们介绍一下吧，这两位就是「荣誉骑士」，和他/她的向导派蒙。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：荣誉骑士？居然是这么不得了的人…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：这位是希奥多，第八小队的见习医师，跟你们一样，也是洛恩的朋友。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：洛恩？…朋友？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：不必这么惊讶吧，我的「朋友」可多了，对吧，派蒙？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：是、是…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：（不知道这个「朋友」的「朋友费」是多少…）\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：嗯…？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：希奥多，你的本职工作是救护跟医疗吧？怎么接上测试员的活了？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：呃，我也参与了这个「模拟测试」的搭建工作，多少了解一点基本原理。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：而且我好歹也是以骑士为目标锻炼过的，就算出了什么事，应该也能自己治疗一下…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：不过现在洛恩副队长愿意接手的话，就不用勉强了吧。前线骑士的测试数据，也会更符合实际需要？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：是、是啊…交给洛恩，会更好…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：打起点精神来，希奥多，要是洛恩出了什么状况，还得指望你来治呢。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e希奥多：…嗯。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：虽然我不觉得有什么记忆能伤到我就是了——开始吧，老头子。\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e挑战记忆中的强敌\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e洛恩：来吧，老头子，让我看看你都见识过什么精锐！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：嘿，可别大意，我从前也是跟着大团长到处征战过的！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：一戳就散的家伙，不值一提。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：哈…还没远征路上遇到过的免子凶猛，我都快睡着了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：这个大家伙就叫秘源机兵？和玩具也没两样啊。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：唉，看来老头子的记忆，是难不倒你咯。\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e与洛恩对话\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e砂糖：痛觉参数完全没有波动…呃，是不是该换个更普通一点的测试员…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：——不用换，接着测。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：还要继续吗？凭我的记忆，恐怕没什么好打的…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：我们之中不是还有一位「骑士」，面对过更可怕的家伙吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：来吧，旅行者，让我看看…你记忆里的「猎月人」。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"q91v5uq0lT1781799083558\":{\"option\":\"（提前一晚在酒里下药…）\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e莱夫赫姆：咕…我的肚子…我的肚子！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"q9zkrks65xpT1781800049386\":{\"option\":\"旅行者：习惯了。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：难以想象，那个「荣誉骑士」居然成天在做这些事…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：我们也不是每天都在对付想毁灭世界的家伙啦…不如说这种家伙要是每天都有也太恐怖了吧！\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"qd4j3oao1khT1781797893627\":{\"option\":\"旅行者：那还是先去见见吧…\",\"dialogue\":\"\",\"icon\":\"\"},\"rd1xopcbacgT1781797603230\":{\"option\":\"旅行者：你这么一说还真是…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e凯亚：哦？那我就期待一下，大前辈在授勋仪式上的风采吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：话说回来，这次会有哪些骑士拿到「称号」？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：这次的「称号」呀，主要会授予在远征中做出过杰出贡献的骑士们：温弗里德、莱夫赫姆…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：还有第五小队的副队长，洛恩。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：洛恩？原来他还没获得过称号吗？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：嗯…从能力上来说，他在远征之前就该获得属于自己的称号了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：但毕竟他加入骑士团的时间尚短，又因为一些私人的原因，一直拖到了现在。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：根据小道消息，这一次他不仅会在仪式上获得称号，还将正式接任第五小队的队长之职…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：嘿，估计会打破某人留下的纪录呢。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"ro64hk4mflpT1719539060545\":{\"option\":\"旅行者：…我，我只是路过。\",\"dialogue\":\"\u003cp\u003e\u003c/p\u003e\",\"icon\":\"\"},\"rvuo4nca4gT1719539843432\":{\"option\":\"旅行者：如果对规则有意见的话…\",\"dialogue\":\"\",\"icon\":\"\"},\"t72xhysj3kiT1781797662544\":{\"option\":\"旅行者：什么记录？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e凯亚：「西风骑士团最年轻的队长」——上一任记录的保持者是前骑兵队长，迪卢克。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：呵…真好奇到时候，「前队长」会是一副什么表情。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"t8cua8s5whbT1781797751340\":{\"option\":\"旅行者：你退步了啊…派蒙。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：才没退步！那家伙太难概括了…所以究竟是什么啦？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：嗯，现在赔率…啊不，可能性最高的「称号」是…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：——「仁蔼骑士」。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：…仁…蔼…？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：——这有半个字跟他沾边吗！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：哈哈，这个故事要讲起来可就长了。可惜，好像有人来找你了。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e波尔托：荣誉骑士！荣誉骑士！谢天谢地，您真在这里。\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"tet31r5v8vaT1781799129532\":{\"option\":\"（在训练场地挖好陷阱…）\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e艾克贝特：我们一拥而上，副队长难道能把所有人都给挑了？大家一起上——啊——\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：哼，实战要比训练困难十倍，敌人要比我狡猾一百倍。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：都给我记好了——上了战场，能「信任」的就只有你们自己！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：为了保障「朋友」的绝对安全，我每晚都会去排除据点四周潜在的隐患…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：嗯…警戒跟侦查，确实也是身为一队之长需要注意的事情…\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e消灭全部敌人\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e洛恩：…警戒？侦查？何必那么麻烦？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：只要敌人全部安安静静地消失，就不会扰人清梦了呀。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：哈…让「朋友」们都能安安静静睡个好觉，这点工作不算什么。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：当然，为了帮远征军收集情报，时刻保持「人脉」…还有跟「朋友」们的真诚交流，也是很有必要的…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：哈哈，没想到你这一趟下来，还真懂事了不少…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：来，让我再往切口上撒点盐…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"tf3um73ue0nT1781799610085\":{\"option\":\"（全都撒上！）\",\"dialogue\":\"\",\"icon\":\"\"},\"tkh2kxc1f8T1719539330274\":{\"option\":\"旅行者：…那还真是天大的麻烦！\",\"dialogue\":\"\u003cp\u003e娜维娅：你果然也这么觉得吧？我的好搭档。\u003c/p\u003e\u003cp\u003e派蒙：但我和旅行者是两个人欸，这没问题吗？\u003c/p\u003e\u003cp\u003e克洛琳德：没问题，我会根据实际参与人数进行节奏的把控，保证你们的游玩体验。\u003c/p\u003e\u003cp\u003e派蒙：嘿嘿，你怎么看？想玩吗？我听你的。\u003c/p\u003e\",\"icon\":\"\"},\"tngl2pvouh8T1781798546263\":{\"option\":\"旅行者：这算哪门子朋友啊！\",\"dialogue\":\"\",\"icon\":\"\"},\"u1kt1x06dhrT1781801099001\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：…老头子，我们可没必要活在那种混蛋的阴影里。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：…嗯，你们说得在理，将来的日子还长着呢。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：去做下一项工作吧…这回应该能让你们提起点精神了，是去协助第十小队做点研究。\u003c/span\u003e\u003c/p\u003e\u003ch2 class=\\\"custom-heading-cls\\\" style=\\\"text-align: center\\\"\u003e\u003cstrong\u003e\u003cspan\u003e前去协助实验\u003c/span\u003e\u003c/strong\u003e\u003c/h2\u003e\u003cp\u003e\u003cspan\u003e砂糖：唔…艾莉丝女士留下的魔法，果然不是那么简单就能弄明白的东西。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：嘿！砂糖…咦？这个是…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e旅行者：之前迎接远征军用的泡泡？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：啊，旅行者！你们是来协助「模拟训练泡·零贰式」开发测试的吗！\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：那是…用来重现记忆的魔法泡泡？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"u37ubu7d4jmT1781800995666\":{\"option\":\"旅行者：西风骑士团的前督察长…\",\"dialogue\":\"\",\"icon\":\"\"},\"u4iejoh0me9T1781797882275\":{\"option\":\"旅行者：没准就是想找借口翘班…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e派蒙：无法反驳…不过万一他真有什么要紧事呢？他也不是没有正经的时候…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"vclytr30mpT1781799665747\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：…哦？你这意思，是愿意合作咯？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：呵，既然你愿意合作，那我们以后就是「朋友」啦——可不能互相出卖哦。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：怎么样，旅行者，派蒙？我没说谎吧？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"vipl8ss6f5T1781800307288\":{\"option\":\"旅行者：小菜一碟。\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e洛恩：…嗯，走吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：咦？奇怪，我还以为他会很兴奋呢…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"w7j1eqnclpoT1781803065428\":{\"option\":\"\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：哈哈，我只是年纪老了些，眼睛可还没花呢。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：不过先不管手段如何，能找到愿意陪他演戏的同伴，也多少算他有点长进了吧。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：就算是演的也行，没准多跟着你们学学，他哪天就真能想明白了呢？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e砂糖：唔…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"wr8k7veu7jmT1781798946351\":{\"option\":\"旅行者：…好新颖的打招呼方式…\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e阿多诺：这两位是？\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e洛恩：我的朋友——「荣誉骑士」旅行者，和他/她的向导派蒙。\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e阿多诺：「荣誉骑士」…就是之前解决风魔龙事件的「荣誉骑士」？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"xogs0ebj1kpT1781799107332\":{\"option\":\"（偷偷调换队员的弹药…）\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e温弗里德：这次还有什么招？嗯？什么叫「你的枪里没有子弹」…\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"},\"ys5rto374qbT1719539378017\":{\"option\":\"旅行者：好的剧本怎能不玩！\",\"dialogue\":\"\",\"icon\":\"\"},\"zq8oo4yyukrT1781797673878\":{\"option\":\"旅行者：我猜是面无表情？\",\"dialogue\":\"\u003cp\u003e\u003cspan\u003e凯亚：倒也不一定？至少他当初拿下这个记录的时候，笑容还是很灿烂的…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e派蒙：笑容灿烂的正义人吗…好难想象…\u003c/span\u003e\u003c/p\u003e\u003cp\u003e\u003cspan\u003e凯亚：算啦，先不提这事——你们要不要来猜猜，洛恩副队长这次会被授予什么「称号」？\u003c/span\u003e\u003c/p\u003e\",\"icon\":\"\"}}}],\"root_id\":\"\",\"child_ids\":null,\"contents\":null}\n",
