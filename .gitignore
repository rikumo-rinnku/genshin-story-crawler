# Python 虚拟环境
.venv/
venv/
env/

# Python 编译缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 日志文件
logs/
*.log

# 爬取数据（如果你不希望将爬取的数据上传到仓库）
data/cleaned/
data/raw/
# 但 data/ 下的某些目录可能需要保留结构，可以只忽略内容，但简单做法是忽略整个 data/cleaned/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 环境变量
.env

# 其他临时文件
*.tmp
*.bak

# 增量记录文件（包含已爬取ID）
config/crawled.json